# Copy this to .env and fill in your values.
#
# HOW TO GET YOUR DEVICE CREDENTIALS:
# 1. Create a free account at https://iot.tuya.com (Tuya IoT Platform)
# 2. Create a Cloud project, link your recteq app account under "Devices"
# 3. Find your device — Device ID and Local Key are listed there
# 4. IP address: check your router's DHCP table for your grill's IP,
#    or set a static lease so it doesn't change.
#
# PROTOCOL VERSION:
#   RT-700 (Bull) and similar older models → 3.1
#   Flagship 1100/1600 and newer models    → 3.3 or 3.4

GRILL_DEVICE_ID=your_grill_device_id
GRILL_LOCAL_KEY=your_grill_local_key
GRILL_IP=192.168.1.xxx
GRILL_PROTOCOL=3.4

# Optional: wireless probe hub (recteq Wireless Probe Set)
# Remove or leave blank if you don't have one.
PROBE_DEVICE_ID=your_probe_device_id
PROBE_LOCAL_KEY=your_probe_local_key
PROBE_IP=192.168.1.yyy
PROBE_PROTOCOL=3.4

# Web server port
PORT=8080
